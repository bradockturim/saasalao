generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── Tenant root ──────────────────────────────────────────────────────────────

model Salon {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  email       String   @unique
  phone       String?
  address     String?
  city        String?
  state       String?
  zipCode     String?
  logoUrl     String?
  plan        Plan     @default(FREE)
  planExpiresAt DateTime?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // WhatsApp notifications
  whatsappNumber    String?
  whatsappNotifyNew Boolean @default(false)

  users        User[]
  employees    Employee[]
  services     Service[]
  clients      Client[]
  appointments Appointment[]
  categories   ServiceCategory[]
  workingHours WorkingHour[]

  @@map("salons")
}

// ─── Auth / Users ─────────────────────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  salonId       String
  name          String
  email         String
  password      String
  role          UserRole  @default(STAFF)
  avatarUrl     String?
  isActive      Boolean   @default(true)
  emailVerified DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  salon   Salon   @relation(fields: [salonId], references: [id], onDelete: Cascade)

  @@unique([email, salonId])
  @@index([salonId])
  @@map("users")
}

// ─── Employees ────────────────────────────────────────────────────────────────

model Employee {
  id          String   @id @default(cuid())
  salonId     String
  name        String
  email       String?
  phone       String?
  role        String?
  avatarUrl   String?
  color       String   @default("#8B5CF6")
  commission  Float    @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  specialties  String[]

  salon        Salon         @relation(fields: [salonId], references: [id], onDelete: Cascade)
  appointments         Appointment[] @relation("AppointmentEmployee")
  staffedAppointments  Appointment[] @relation("AppointmentStaff")
  services     EmployeeService[]

  @@index([salonId])
  @@map("employees")
}

model EmployeeService {
  employeeId String
  serviceId  String

  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  service  Service  @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@id([employeeId, serviceId])
  @@map("employee_services")
}

// ─── Services ─────────────────────────────────────────────────────────────────

model ServiceCategory {
  id        String    @id @default(cuid())
  salonId   String
  name      String
  color     String    @default("#8B5CF6")
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  salon    Salon     @relation(fields: [salonId], references: [id], onDelete: Cascade)
  services Service[]

  @@index([salonId])
  @@map("service_categories")
}

model Service {
  id                  String   @id @default(cuid())
  salonId             String
  categoryId          String?
  name                String
  description         String?
  duration            Int      // minutes (base/default)
  price               Float    // base price (used when hasPricingByLength = false)
  hasPricingByLength  Boolean  @default(false)
  isActive            Boolean  @default(true)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  salon        Salon            @relation(fields: [salonId], references: [id], onDelete: Cascade)
  category     ServiceCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  appointments AppointmentService[]
  employees    EmployeeService[]
  pricings     ServicePricing[]

  @@index([salonId])
  @@map("services")
}

model ServicePricing {
  id         String     @id @default(cuid())
  serviceId  String
  salonId    String
  hairLength HairLength
  price      Float
  duration   Int?       // override duration for this length (null = use service.duration)

  service Service @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@unique([serviceId, hairLength])
  @@index([salonId])
  @@map("service_pricings")
}

// ─── Clients ──────────────────────────────────────────────────────────────────

model Client {
  id          String      @id @default(cuid())
  salonId     String
  name        String
  email       String?
  phone       String
  birthDate   DateTime?
  notes       String?
  avatarUrl   String?
  hairType    HairType?
  hairLength  HairLength?
  isActive    Boolean     @default(true)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  salon        Salon         @relation(fields: [salonId], references: [id], onDelete: Cascade)
  appointments Appointment[]

  @@unique([salonId, phone])
  @@index([salonId])
  @@map("clients")
}

// ─── Appointments ─────────────────────────────────────────────────────────────

model Appointment {
  id          String            @id @default(cuid())
  salonId     String
  clientId    String
  employeeId  String
  staffId     String?           // profissional solicitado (null = sem preferência)
  startsAt    DateTime
  endsAt      DateTime
  status      AppointmentStatus @default(SCHEDULED)
  totalPrice  Float
  notes       String?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  salon    Salon     @relation(fields: [salonId], references: [id], onDelete: Cascade)
  client   Client    @relation(fields: [clientId], references: [id], onDelete: Cascade)
  employee Employee  @relation("AppointmentEmployee", fields: [employeeId], references: [id], onDelete: Cascade)
  staff    Employee? @relation("AppointmentStaff",    fields: [staffId],   references: [id], onDelete: SetNull)
  services AppointmentService[]

  @@index([salonId])
  @@index([salonId, startsAt])
  @@index([salonId, employeeId])
  @@index([salonId, clientId])
  @@index([salonId, staffId])
  @@map("appointments")
}

model AppointmentService {
  appointmentId String
  serviceId     String
  price         Float
  duration      Int

  appointment Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  service     Service     @relation(fields: [serviceId], references: [id], onDelete: Restrict)

  @@id([appointmentId, serviceId])
  @@map("appointment_services")
}

// ─── Working Hours ────────────────────────────────────────────────────────────

model WorkingHour {
  id        String  @id @default(cuid())
  salonId   String
  dayOfWeek Int     // 0=Sunday … 6=Saturday
  openTime  String  // "HH:MM"
  closeTime String  // "HH:MM"
  isOpen    Boolean @default(true)

  salon Salon @relation(fields: [salonId], references: [id], onDelete: Cascade)

  @@unique([salonId, dayOfWeek])
  @@index([salonId])
  @@map("working_hours")
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum Plan {
  FREE
  STARTER
  PROFESSIONAL
  ENTERPRISE
}

enum UserRole {
  OWNER
  ADMIN
  STAFF
}

enum AppointmentStatus {
  SCHEDULED
  CONFIRMED
  IN_PROGRESS
  COMPLETED
  CANCELLED
  NO_SHOW
}

enum HairLength {
  SHORT
  MEDIUM
  LONG
}

enum HairType {
  STRAIGHT
  WAVY_CURLY
}
